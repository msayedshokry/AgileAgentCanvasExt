# Source files (compiled output in dist/ is included)
src/**
webview-ui/src/**
# webview-ui/public/ is Vite's static-serve folder for dev only; the same
# assets are emitted to webview-ui/build/ by vite build, which is what the
# extension actually loads at runtime. Including both duplicated the 1.3 MB
# 3d-force-graph.min.js into the VSIX.
webview-ui/public/**
# Standalone webview dev/scratch files (manual 3d-force-graph harness, ad-hoc
# test pages, raw gitify output samples). Not referenced at runtime.
webview-ui/test*
webview-ui/node_modules/**
webview-ui/index.html
webview-ui/tsconfig.json
webview-ui/vite.config.ts
webview-ui/vitest.config.ts
webview-ui/package.json
webview-ui/package-lock.json
webview-ui/coverage/**

# Build tooling (esbuild bundles everything into dist/extension.js)
esbuild.mjs
tsconfig.json
tsconfig.*.json

# Node modules (all deps are bundled by esbuild)
node_modules/**

# Old tsc multi-file output (esbuild produces a single dist/extension.js)
dist/canvas/**
dist/chat/**
dist/commands/**
dist/providers/**
dist/state/**
dist/types/**
dist/views/**
dist/workflow/**
dist/**/*.d.ts
dist/**/*.d.ts.map

# Tests and test output
features/**
coverage/**
reports/**
cucumber.js
**/*.test.ts
**/*.spec.ts

# Dev tooling
.vscode/**
.github/skills/**
.eslintrc*
.eslintignore
.prettier*

# Misc
.gitignore
*.vsix
**/*.map
**/*.ts

# Junk / non-extension files
Antigravity Shortcuts.json
bmad.7z
_index_test.py
nul
opencode.json
*test_errors*
CDATA*
*.py
*.7z
.c8rc.json
package-lock.json
agileagentcanvas-*.vsix
fix-sample-metadata.js
search.js
refactor_logger.js
check-coverage-thresholds.js
patch-workflows.js
test-loaders.js
fix_artifact_store.js
fs.renameSync*

# Python virtual environments (graphify tooling — not part of the extension)
.venv/**
.venv-1/**

# Workspace-specific generated/config files that should not ship
.opencode/**
.agileagentcanvas-context/**
.claude/**
.agent/**
graphify-out/**
docs/**
