{
  "name": "bmad-canvas-webview",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./test/a11y-tokens": "./src/test/a11y-tokens.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prebuild": "node -e \"const fs=require('fs'),path=require('path');fs.mkdirSync(path.join('public','3d-force-graph'),{recursive:true});fs.cpSync(path.join(path.dirname(require.resolve('3d-force-graph')),'3d-force-graph.min.js'),path.join('public','3d-force-graph','3d-force-graph.min.js'));\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "3d-force-graph": "^1.80.0",
    "html2canvas": "^1.4.1",
    "marked": "^17.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@types/vscode-webview": "^1.57.5",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.0.18"
  }
}
