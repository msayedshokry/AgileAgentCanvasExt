{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmad.dev/schemas/bmm/ux-design.schema.json",
  "title": "UX Design Specification Schema",
  "description": "Comprehensive schema for UX design artifacts - captures COMPLETE user experience design specifications, design system, and user journeys",
  "type": "object",
  "required": [
    "metadata",
    "content"
  ],
  "properties": {
    "metadata": {
      "$ref": "../common/metadata.schema.json"
    },
    "content": {
      "type": "object",
      "required": [
        "designSystem"
      ],
      "properties": {
        "overview": {
          "type": "object",
          "description": "Design overview - capture COMPLETE design context",
          "properties": {
            "productName": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "designPhilosophy": {
              "type": "string",
              "description": "COMPLETE design philosophy description"
            },
            "targetExperience": {
              "type": "string",
              "description": "COMPLETE target experience description"
            },
            "designPrinciples": {
              "type": "array",
              "description": "ALL guiding design principles",
              "items": {
                "type": "object",
                "properties": {
                  "principle": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string",
                    "description": "COMPLETE principle description"
                  },
                  "examples": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "designGoals": {
              "type": "array",
              "description": "Design goals",
              "items": {
                "type": "object",
                "properties": {
                  "goal": {
                    "type": "string"
                  },
                  "metrics": {
                    "type": "string"
                  },
                  "rationale": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "coreExperience": {
          "type": "object",
          "description": "Core experience definition - capture COMPLETE details",
          "properties": {
            "primaryValue": {
              "type": "string",
              "description": "COMPLETE primary value proposition from UX perspective"
            },
            "keyInteractions": {
              "type": "array",
              "description": "ALL key interactions",
              "items": {
                "type": "object",
                "properties": {
                  "interaction": {
                    "type": "string",
                    "description": "COMPLETE interaction description"
                  },
                  "purpose": {
                    "type": "string"
                  },
                  "frequency": {
                    "type": "string"
                  }
                }
              }
            },
            "emotionalGoals": {
              "type": "array",
              "description": "ALL emotional goals",
              "items": {
                "type": "object",
                "properties": {
                  "emotion": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "triggers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "userFlowSummary": {
              "type": "string",
              "description": "COMPLETE summary of main user flows"
            }
          }
        },
        "designInspiration": {
          "type": "array",
          "description": "ALL design inspiration and references - capture completely",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "description": "Inspiration source (e.g., app name, website)"
              },
              "url": {
                "type": "string"
              },
              "aspect": {
                "type": "string",
                "description": "COMPLETE description of what aspect is inspiring"
              },
              "application": {
                "type": "string",
                "description": "COMPLETE description of how this will be applied"
              },
              "screenshots": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "designSystem": {
          "type": "object",
          "description": "COMPLETE design system specification",
          "properties": {
            "overview": {
              "type": "string",
              "description": "COMPLETE design system overview"
            },
            "colorPalette": {
              "type": "object",
              "description": "Complete color palette",
              "properties": {
                "description": {
                  "type": "string"
                },
                "primary": {
                  "type": "array",
                  "description": "ALL primary colors",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string",
                        "description": "COMPLETE usage description"
                      },
                      "variants": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string"
                            },
                            "value": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "secondary": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                },
                "neutral": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                },
                "semantic": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "string"
                        },
                        "usage": {
                          "type": "string"
                        }
                      }
                    },
                    "warning": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "string"
                        },
                        "usage": {
                          "type": "string"
                        }
                      }
                    },
                    "error": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "string"
                        },
                        "usage": {
                          "type": "string"
                        }
                      }
                    },
                    "info": {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "string"
                        },
                        "usage": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "darkMode": {
                  "type": "object",
                  "description": "Dark mode color mappings",
                  "properties": {
                    "supported": {
                      "type": "boolean"
                    },
                    "mappings": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "lightValue": {
                            "type": "string"
                          },
                          "darkValue": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "typography": {
              "type": "object",
              "description": "Complete typography system",
              "properties": {
                "description": {
                  "type": "string"
                },
                "fontFamilies": {
                  "type": "array",
                  "description": "ALL font families",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string",
                        "description": "COMPLETE usage description"
                      },
                      "fallbacks": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "source": {
                        "type": "string"
                      },
                      "weights": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "scale": {
                  "type": "array",
                  "description": "ALL typography scale entries",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "size": {
                        "type": "string"
                      },
                      "lineHeight": {
                        "type": "string"
                      },
                      "weight": {
                        "type": "string"
                      },
                      "letterSpacing": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string",
                        "description": "COMPLETE usage description"
                      }
                    }
                  }
                },
                "textStyles": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "properties": {
                        "type": "object"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "spacing": {
              "type": "object",
              "description": "Spacing system",
              "properties": {
                "description": {
                  "type": "string"
                },
                "baseUnit": {
                  "type": "string"
                },
                "scale": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "borders": {
              "type": "object",
              "description": "Border system",
              "properties": {
                "radii": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                },
                "widths": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "shadows": {
              "type": "array",
              "description": "Shadow system",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "usage": {
                    "type": "string"
                  }
                }
              }
            },
            "iconography": {
              "type": "object",
              "description": "Icon system",
              "properties": {
                "library": {
                  "type": "string"
                },
                "sizes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                },
                "style": {
                  "type": "string"
                },
                "customIcons": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "animation": {
              "type": "object",
              "description": "Animation and motion design",
              "properties": {
                "principles": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "durations": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                },
                "easings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "usage": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "userJourneys": {
          "type": "array",
          "description": "ALL user journey maps - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string",
                "description": "COMPLETE journey description"
              },
              "persona": {
                "type": "string"
              },
              "goal": {
                "type": "string",
                "description": "COMPLETE user goal for this journey"
              },
              "trigger": {
                "type": "string"
              },
              "stages": {
                "type": "array",
                "description": "ALL journey stages - capture completely",
                "items": {
                  "type": "object",
                  "properties": {
                    "stage": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string",
                      "description": "COMPLETE stage description"
                    },
                    "actions": {
                      "type": "array",
                      "description": "ALL user actions",
                      "items": {
                        "type": "object",
                        "properties": {
                          "action": {
                            "type": "string"
                          },
                          "details": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "thoughts": {
                      "type": "string",
                      "description": "COMPLETE user thoughts/mindset"
                    },
                    "emotions": {
                      "type": "string",
                      "description": "Emotional state"
                    },
                    "emotionScore": {
                      "type": "integer",
                      "minimum": -5,
                      "maximum": 5
                    },
                    "touchpoints": {
                      "type": "array",
                      "description": "ALL UI touchpoints",
                      "items": {
                        "type": "object",
                        "properties": {
                          "touchpoint": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "painPoints": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "opportunities": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "successCriteria": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "metrics": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "metric": {
                      "type": "string"
                    },
                    "target": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "wireframes": {
          "type": "array",
          "description": "Wireframe specifications",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string",
                "description": "COMPLETE wireframe description"
              },
              "type": {
                "type": "string",
                "description": "Recommended values: low-fidelity, mid-fidelity, high-fidelity — or any domain-appropriate value"
              },
              "screens": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "elements": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "interactions": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "reference": {
                "type": "string"
              }
            }
          }
        },
        "componentStrategy": {
          "type": "object",
          "description": "Component design strategy - capture COMPLETE details",
          "properties": {
            "overview": {
              "type": "string",
              "description": "COMPLETE component strategy overview"
            },
            "componentLibrary": {
              "type": "string",
              "description": "Base component library being used"
            },
            "customizationApproach": {
              "type": "string",
              "description": "How library components will be customized"
            },
            "customComponents": {
              "type": "array",
              "description": "ALL custom components to be created",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "purpose": {
                    "type": "string",
                    "description": "COMPLETE purpose description"
                  },
                  "description": {
                    "type": "string",
                    "description": "COMPLETE component description"
                  },
                  "props": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        },
                        "required": {
                          "type": "boolean"
                        }
                      }
                    }
                  },
                  "states": {
                    "type": "array",
                    "description": "ALL component states",
                    "items": {
                      "type": "object",
                      "properties": {
                        "state": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "variants": {
                    "type": "array",
                    "description": "ALL component variants",
                    "items": {
                      "type": "object",
                      "properties": {
                        "variant": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "accessibility": {
                    "type": "object",
                    "properties": {
                      "role": {
                        "type": "string"
                      },
                      "ariaAttributes": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "keyboardInteraction": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "pageLayouts": {
          "type": "array",
          "description": "Page layout specifications",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string",
                "description": "COMPLETE layout description"
              },
              "type": {
                "type": "string"
              },
              "structure": {
                "type": "object",
                "properties": {
                  "header": {
                    "type": "string"
                  },
                  "sidebar": {
                    "type": "string"
                  },
                  "main": {
                    "type": "string"
                  },
                  "footer": {
                    "type": "string"
                  }
                }
              },
              "components": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "responsiveBehavior": {
                "type": "string"
              }
            }
          }
        },
        "uxPatterns": {
          "type": "array",
          "description": "ALL UX patterns to implement - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string"
              },
              "category": {
                "type": "string",
                "description": "Recommended values: navigation, input, feedback, data-display, layout, interaction — or any domain-appropriate value"
              },
              "usage": {
                "type": "string",
                "description": "COMPLETE usage description"
              },
              "implementation": {
                "type": "string",
                "description": "COMPLETE implementation guidance"
              },
              "examples": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rationale": {
                "type": "string"
              }
            }
          }
        },
        "responsive": {
          "type": "object",
          "description": "Responsive design specifications - capture COMPLETE details",
          "properties": {
            "strategy": {
              "type": "string",
              "description": "COMPLETE responsive strategy (e.g., 'mobile-first', 'desktop-first')"
            },
            "breakpoints": {
              "type": "array",
              "description": "ALL breakpoints",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "minWidth": {
                    "type": "string"
                  },
                  "maxWidth": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "layoutChanges": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "adaptiveElements": {
              "type": "array",
              "description": "Elements with special responsive behavior",
              "items": {
                "type": "object",
                "properties": {
                  "element": {
                    "type": "string"
                  },
                  "behavior": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "accessibility": {
          "type": "object",
          "description": "Accessibility requirements - capture COMPLETE details",
          "properties": {
            "standard": {
              "type": "string",
              "description": "Accessibility standard (e.g., 'WCAG 2.1 AA')"
            },
            "overview": {
              "type": "string",
              "description": "COMPLETE accessibility overview"
            },
            "requirements": {
              "type": "array",
              "description": "ALL accessibility requirements",
              "items": {
                "type": "object",
                "properties": {
                  "requirement": {
                    "type": "string",
                    "description": "COMPLETE requirement description"
                  },
                  "category": {
                    "type": "string",
                    "description": "Recommended values: perceivable, operable, understandable, robust — or any domain-appropriate value"
                  },
                  "implementation": {
                    "type": "string"
                  },
                  "testing": {
                    "type": "string"
                  }
                }
              }
            },
            "keyboardNavigation": {
              "type": "object",
              "properties": {
                "strategy": {
                  "type": "string"
                },
                "focusManagement": {
                  "type": "string"
                },
                "shortcuts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "keys": {
                        "type": "string"
                      },
                      "action": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "screenReaderSupport": {
              "type": "object",
              "properties": {
                "approach": {
                  "type": "string"
                },
                "announcements": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "colorContrast": {
              "type": "object",
              "properties": {
                "minimumRatio": {
                  "type": "string"
                },
                "largeTextRatio": {
                  "type": "string"
                }
              }
            }
          }
        },
        "interactions": {
          "type": "array",
          "description": "Interaction design specifications",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "trigger": {
                "type": "string"
              },
              "response": {
                "type": "string",
                "description": "COMPLETE response description"
              },
              "feedback": {
                "type": "string"
              },
              "animation": {
                "type": "string"
              },
              "states": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "errorStates": {
          "type": "array",
          "description": "Error state designs",
          "items": {
            "type": "object",
            "properties": {
              "errorType": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "display": {
                "type": "string"
              },
              "recovery": {
                "type": "string"
              }
