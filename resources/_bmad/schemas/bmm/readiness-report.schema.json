{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmad.dev/schemas/bmm/readiness-report.schema.json",
  "title": "Implementation Readiness Report Schema",
  "description": "Comprehensive schema for readiness report artifacts - captures COMPLETE implementation readiness assessment with full analysis and recommendations",
  "type": "object",
  "required": ["metadata", "content"],
  "properties": {
    "metadata": {
      "$ref": "../common/metadata.schema.json"
    },
    "content": {
      "type": "object",
      "required": ["summary", "assessment"],
      "properties": {
        "summary": {
          "type": "object",
          "description": "Executive summary - capture COMPLETE assessment overview",
          "properties": {
            "projectName": { "type": "string" },
            "assessmentDate": {
              "type": "string",
              "format": "date"
            },
            "assessedBy": { "type": "string" },
            "overallStatus": {
              "type": "string",
              "enum": ["ready", "ready-with-concerns", "not-ready", "blocked"]
            },
            "overallScore": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "recommendation": {
              "type": "string",
              "description": "COMPLETE recommendation for proceeding"
            },
            "keyFindings": {
              "type": "array",
              "description": "ALL key findings - capture completely",
              "items": { "type": "string" }
            },
            "criticalActions": {
              "type": "array",
              "description": "Critical actions required before proceeding",
              "items": { "type": "string" }
            }
          }
        },
        "assessment": {
          "type": "object",
          "description": "COMPLETE detailed assessment",
          "properties": {
            "prdAnalysis": {
              "type": "object",
              "description": "PRD analysis - capture COMPLETE findings",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["complete", "incomplete", "missing", "needs-revision"]
                },
                "completeness": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                },
                "summary": {
                  "type": "string",
                  "description": "COMPLETE PRD analysis summary"
                },
                "findings": {
                  "type": "array",
                  "description": "ALL findings - capture completely",
                  "items": {
                    "type": "object",
                    "properties": {
                      "finding": {
                        "type": "string",
                        "description": "COMPLETE finding description"
                      },
                      "type": {
                        "type": "string",
                        "enum": ["positive", "concern", "gap", "issue"]
                      },
                      "severity": {
                        "type": "string",
                        "enum": ["low", "medium", "high", "critical"]
                      },
                      "recommendation": { "type": "string" }
                    }
                  }
                },
                "gaps": {
                  "type": "array",
                  "description": "ALL identified gaps",
                  "items": {
                    "type": "object",
                    "properties": {
                      "gap": {
                        "type": "string",
                        "description": "COMPLETE gap description"
                      },
                      "impact": { "type": "string" },
                      "remediation": { "type": "string" }
                    }
                  }
                },
                "strengths": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "epicCoverage": {
              "type": "object",
              "description": "Epic coverage analysis - capture COMPLETE details",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["complete", "incomplete", "missing", "needs-work"]
                },
                "summary": {
                  "type": "string",
                  "description": "COMPLETE coverage summary"
                },
                "totalRequirements": { "type": "integer" },
                "coveredRequirements": { "type": "integer" },
                "coveragePercent": { "type": "number" },
                "byType": {
                  "type": "object",
                  "properties": {
                    "functional": {
                      "type": "object",
                      "properties": {
                        "total": { "type": "integer" },
                        "covered": { "type": "integer" },
                        "percentage": { "type": "number" }
                      }
                    },
                    "nonFunctional": {
                      "type": "object",
                      "properties": {
                        "total": { "type": "integer" },
                        "covered": { "type": "integer" },
                        "percentage": { "type": "number" }
                      }
                    },
                    "additional": {
                      "type": "object",
                      "properties": {
                        "total": { "type": "integer" },
                        "covered": { "type": "integer" },
                        "percentage": { "type": "number" }
                      }
                    }
                  }
                },
                "gaps": {
                  "type": "array",
                  "description": "ALL coverage gaps - capture completely",
                  "items": {
                    "type": "object",
                    "properties": {
                      "requirementId": { "type": "string" },
                      "requirementTitle": { "type": "string" },
                      "description": {
                        "type": "string",
                        "description": "COMPLETE gap description"
                      },
                      "severity": {
                        "type": "string",
                        "enum": ["low", "medium", "high", "critical"]
                      },
                      "recommendation": { "type": "string" }
                    }
                  }
                },
                "overCoverage": {
                  "type": "array",
                  "description": "Stories not mapped to requirements",
                  "items": {
                    "type": "object",
                    "properties": {
                      "storyId": { "type": "string" },
                      "note": { "type": "string" }
                    }
                  }
                }
              }
            },
            "uxAlignment": {
              "type": "object",
              "description": "UX alignment analysis - capture COMPLETE details",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["aligned", "partial", "misaligned", "not-applicable"]
                },
                "summary": {
                  "type": "string",
                  "description": "COMPLETE UX alignment summary"
                },
                "findings": {
                  "type": "array",
                  "description": "ALL UX alignment findings",
                  "items": {
                    "type": "object",
                    "properties": {
                      "finding": {
                        "type": "string",
                        "description": "COMPLETE finding"
                      },
                      "type": {
                        "type": "string",
                        "enum": ["aligned", "gap", "conflict"]
                      },
                      "severity": { "type": "string" },
                      "recommendation": { "type": "string" }
                    }
                  }
                },
                "designSystemCoverage": { "type": "string" },
                "accessibilityReadiness": { "type": "string" }
              }
            },
            "architectureReadiness": {
              "type": "object",
              "description": "Architecture readiness - capture COMPLETE details",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["ready", "needs-work", "missing", "incomplete"]
                },
                "summary": {
                  "type": "string",
                  "description": "COMPLETE architecture readiness summary"
                },
                "findings": {
                  "type": "array",
                  "description": "ALL architecture findings",
                  "items": {
                    "type": "object",
                    "properties": {
                      "finding": {
                        "type": "string",
                        "description": "COMPLETE finding"
                      },
                      "type": { "type": "string" },
                      "recommendation": { "type": "string" }
                    }
                  }
                },
                "techStackValidation": { "type": "string" },
                "scalabilityAssessment": { "type": "string" },
                "securityAssessment": { "type": "string" }
              }
            },
            "epicQuality": {
              "type": "object",
              "description": "Epic/story quality assessment - capture COMPLETE details",
              "properties": {
                "overallQuality": {
                  "type": "string",
                  "enum": ["high", "good", "acceptable", "needs-improvement", "poor"]
                },
                "summary": {
                  "type": "string",
                  "description": "COMPLETE quality summary"
                },
                "acceptanceCriteriaQuality": {
                  "type": "object",
                  "properties": {
                    "rating": { "type": "string" },
                    "details": {
                      "type": "string",
                      "description": "COMPLETE AC quality details"
                    },
                    "issues": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                },
                "storyClarity": {
                  "type": "object",
                  "properties": {
                    "rating": { "type": "string" },
                    "details": {
                      "type": "string",
                      "description": "COMPLETE story clarity details"
                    },
                    "issues": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                },
                "technicalFeasibility": {
                  "type": "object",
                  "properties": {
                    "rating": { "type": "string" },
                    "details": {
                      "type": "string",
                      "description": "COMPLETE feasibility details"
                    },
                    "concerns": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                },
                "estimationQuality": {
                  "type": "object",
                  "properties": {
                    "rating": { "type": "string" },
                    "details": { "type": "string" }
                  }
                },
                "dependencyMapping": {
                  "type": "object",
                  "properties": {
                    "rating": { "type": "string" },
                    "details": { "type": "string" }
                  }
                },
                "findings": {
                  "type": "array",
                  "description": "ALL quality findings",
                  "items": {
                    "type": "object",
                    "properties": {
                      "finding": {
                        "type": "string",
                        "description": "COMPLETE finding"
                      },
                      "category": { "type": "string" },
                      "recommendation": { "type": "string" }
                    }
                  }
                }
              }
            },
            "testReadiness": {
              "type": "object",
              "description": "Test readiness assessment",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["ready", "partial", "not-ready"]
                },
                "summary": { "type": "string" },
                "testPlanStatus": { "type": "string" },
                "testCaseCoverage": { "type": "string" },
                "automationReadiness": { "type": "string" },
                "findings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "finding": { "type": "string" },
                      "recommendation": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "blockers": {
          "type": "array",
          "description": "ALL critical blockers - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "blocker": {
                "type": "string",
                "description": "COMPLETE blocker description"
              },
              "category": {
                "type": "string",
                "enum": ["technical", "resource", "dependency", "documentation", "organizational"]
              },
              "impact": {
                "type": "string",
                "description": "COMPLETE impact description"
              },
              "severity": {
                "type": "string",
                "enum": ["critical", "high"]
              },
              "resolution": {
                "type": "string",
                "description": "COMPLETE resolution approach"
              },
              "owner": { "type": "string" },
              "estimatedEffort": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["open", "in-progress", "resolved"]
              }
            }
          }
        },
        "risks": {
          "type": "array",
          "description": "ALL identified risks - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "risk": {
                "type": "string",
                "description": "COMPLETE risk description"
              },
              "category": {
                "type": "string",
                "enum": ["technical", "schedule", "resource", "scope", "quality", "external"]
              },
              "probability": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "impact": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "riskScore": { "type": "integer" },
              "mitigation": {
                "type": "string",
                "description": "COMPLETE mitigation strategy"
              },
              "contingency": { "type": "string" },
              "owner": { "type": "string" },
              "triggers": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "description": "ALL recommendations before proceeding - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "recommendation": {
                "type": "string",
                "description": "COMPLETE recommendation"
              },
              "category": { "type": "string" },
              "priority": {
                "type": "string",
                "enum": ["must-do", "should-do", "nice-to-have"]
              },
              "effort": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "impact": {
                "type": "string",
                "description": "COMPLETE impact description"
              },
              "owner": { "type": "string" },
              "deadline": { "type": "string" }
            }
          }
        },
        "dependencyAnalysis": {
          "type": "object",
          "description": "Dependency analysis",
          "properties": {
            "summary": { "type": "string" },
            "externalDependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "dependency": { "type": "string" },
                  "status": { "type": "string" },
                  "risk": { "type": "string" }
                }
              }
            },
            "internalDependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "dependency": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            },
            "criticalPath": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "resourceAssessment": {
          "type": "object",
          "description": "Resource readiness assessment",
          "properties": {
            "summary": { "type": "string" },
            "teamReadiness": { "type": "string" },
            "skillGaps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "skill": { "type": "string" },
                  "gap": { "type": "string" },
                  "mitigation": { "type": "string" }
                }
              }
            },
            "toolsReadiness": { "type": "string" },
            "environmentReadiness": { "type": "string" }
          }
        },
        "nextSteps": {
          "type": "array",
          "description": "ALL recommended next steps - capture completely",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "integer" },
              "action": {
                "type": "string",
                "description": "COMPLETE action description"
              },
              "owner": { "type": "string" },
              "deadline": { "type": "string" },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "appendices": {
          "type": "array",
          "description": "Supporting materials",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "type": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
