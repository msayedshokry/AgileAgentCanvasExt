{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmad.dev/schemas/bmm/project-overview.schema.json",
  "title": "Project Overview Schema",
  "description": "Comprehensive schema for project overview artifacts - captures COMPLETE brownfield project documentation and analysis",
  "type": "object",
  "required": ["metadata", "content"],
  "properties": {
    "metadata": {
      "$ref": "../common/metadata.schema.json"
    },
    "content": {
      "type": "object",
      "required": ["projectInfo"],
      "properties": {
        "projectInfo": {
          "type": "object",
          "description": "Basic project information",
          "properties": {
            "name": { "type": "string" },
            "description": {
              "type": "string",
              "description": "COMPLETE project description"
            },
            "type": { "type": "string" },
            "architecturePattern": { "type": "string" },
            "version": { "type": "string" },
            "repository": { "type": "string" },
            "license": { "type": "string" }
          }
        },
        "executiveSummary": {
          "type": "string",
          "description": "COMPLETE executive summary of the project - capture all details"
        },
        "projectClassification": {
          "type": "object",
          "description": "Project classification details",
          "properties": {
            "repositoryType": {
              "type": "string",
              "enum": ["monorepo", "single", "multi-repo"]
            },
            "projectTypes": {
              "type": "array",
              "description": "ALL project types",
              "items": { "type": "string" }
            },
            "primaryLanguages": {
              "type": "array",
              "items": { "type": "string" }
            },
            "secondaryLanguages": {
              "type": "array",
              "items": { "type": "string" }
            },
            "architecturePattern": { "type": "string" },
            "maturityLevel": {
              "type": "string",
              "enum": ["prototype", "mvp", "production", "legacy"]
            },
            "complexity": {
              "type": "string",
              "enum": ["simple", "moderate", "complex", "very-complex"]
            }
          }
        },
        "multiPartStructure": {
          "type": "array",
          "description": "Multi-part structure (for monorepos) - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "partId": { "type": "string" },
              "name": { "type": "string" },
              "path": { "type": "string" },
              "description": {
                "type": "string",
                "description": "COMPLETE part description"
              },
              "techStack": { "type": "string" },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "entryPoints": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "techStackSummary": {
          "type": "object",
          "description": "COMPLETE technology stack overview",
          "properties": {
            "overview": {
              "type": "string",
              "description": "COMPLETE tech stack overview"
            },
            "frontend": {
              "type": "array",
              "description": "ALL frontend technologies",
              "items": {
                "type": "object",
                "properties": {
                  "technology": { "type": "string" },
                  "version": { "type": "string" },
                  "purpose": { "type": "string" }
                }
              }
            },
            "backend": {
              "type": "array",
              "description": "ALL backend technologies",
              "items": {
                "type": "object",
                "properties": {
                  "technology": { "type": "string" },
                  "version": { "type": "string" },
                  "purpose": { "type": "string" }
                }
              }
            },
            "database": {
              "type": "array",
              "description": "ALL database technologies",
              "items": {
                "type": "object",
                "properties": {
                  "technology": { "type": "string" },
                  "version": { "type": "string" },
                  "purpose": { "type": "string" }
                }
              }
            },
            "infrastructure": {
              "type": "array",
              "description": "ALL infrastructure components",
              "items": {
                "type": "object",
                "properties": {
                  "technology": { "type": "string" },
                  "purpose": { "type": "string" }
                }
              }
            },
            "testing": {
              "type": "array",
              "description": "ALL testing technologies",
              "items": {
                "type": "object",
                "properties": {
                  "technology": { "type": "string" },
                  "purpose": { "type": "string" }
                }
              }
            },
            "devTools": {
              "type": "array",
              "description": "Development tools",
              "items": {
                "type": "object",
                "properties": {
                  "tool": { "type": "string" },
                  "purpose": { "type": "string" }
                }
              }
            }
          }
        },
        "keyFeatures": {
          "type": "array",
          "description": "ALL key features of the project - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "feature": {
                "type": "string",
                "description": "COMPLETE feature description"
              },
              "status": {
                "type": "string",
                "enum": ["implemented", "partial", "planned"]
              },
              "location": { "type": "string" }
            }
          }
        },
        "architectureHighlights": {
          "type": "array",
          "description": "ALL architecture highlights - capture COMPLETE details",
          "items": {
            "type": "object",
            "properties": {
              "highlight": {
                "type": "string",
                "description": "COMPLETE architecture highlight"
              },
              "category": { "type": "string" },
              "details": { "type": "string" }
            }
          }
        },
        "codebaseAnalysis": {
          "type": "object",
          "description": "Codebase analysis results",
          "properties": {
            "totalFiles": { "type": "integer" },
            "totalLines": { "type": "integer" },
            "languageBreakdown": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "language": { "type": "string" },
                  "percentage": { "type": "number" },
                  "files": { "type": "integer" }
                }
              }
            },
            "codeQuality": {
              "type": "object",
              "properties": {
                "testCoverage": { "type": "string" },
                "documentationLevel": { "type": "string" },
                "lintingStatus": { "type": "string" },
                "technicalDebt": { "type": "string" }
              }
            },
            "patterns": {
              "type": "array",
              "description": "Identified patterns in codebase",
              "items": {
                "type": "object",
                "properties": {
                  "pattern": { "type": "string" },
                  "usage": { "type": "string" },
                  "locations": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "development": {
          "type": "object",
          "description": "Development overview - capture COMPLETE details",
          "properties": {
            "prerequisites": {
              "type": "array",
              "description": "ALL prerequisites",
              "items": {
                "type": "object",
                "properties": {
                  "prerequisite": {
                    "type": "string",
                    "description": "COMPLETE prerequisite description"
                  },
                  "version": { "type": "string" },
                  "installation": { "type": "string" }
                }
              }
            },
            "gettingStarted": {
              "type": "array",
              "description": "ALL getting started steps",
              "items": {
                "type": "object",
                "properties": {
                  "step": { "type": "integer" },
                  "description": {
                    "type": "string",
                    "description": "COMPLETE step description"
                  },
                  "command": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            },
            "keyCommands": {
              "type": "array",
              "description": "ALL key commands",
              "items": {
                "type": "object",
                "properties": {
                  "command": { "type": "string" },
                  "description": {
                    "type": "string",
                    "description": "COMPLETE command description"
                  },
                  "usage": { "type": "string" }
                }
              }
            },
            "environmentVariables": {
              "type": "array",
              "description": "Required environment variables",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "required": { "type": "boolean" },
                  "example": { "type": "string" }
                }
              }
            },
            "configurationFiles": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "purpose": { "type": "string" }
                }
              }
            }
          }
        },
        "repositoryStructure": {
          "type": "array",
          "description": "COMPLETE repository structure summary",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "purpose": {
                "type": "string",
                "description": "COMPLETE purpose description"
              },
              "contents": {
                "type": "string",
                "description": "Description of contents"
              },
              "importance": {
                "type": "string",
                "enum": ["critical", "important", "standard"]
              }
            }
          }
        },
        "entryPoints": {
          "type": "array",
          "description": "ALL application entry points",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "type": { "type": "string" },
              "description": {
                "type": "string",
                "description": "COMPLETE entry point description"
              }
            }
          }
        },
        "dataFlows": {
          "type": "array",
          "description": "Key data flows in the application",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": {
                "type": "string",
                "description": "COMPLETE data flow description"
              },
              "components": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "integrations": {
          "type": "array",
          "description": "External integrations",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "description": {
                "type": "string",
                "description": "COMPLETE integration description"
              },
              "status": { "type": "string" }
            }
          }
        },
        "knownIssues": {
          "type": "array",
          "description": "Known issues and technical debt",
          "items": {
            "type": "object",
            "properties": {
              "issue": {
                "type": "string",
                "description": "COMPLETE issue description"
              },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "location": { "type": "string" },
              "workaround": { "type": "string" }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "description": "Recommendations for improvement",
          "items": {
            "type": "object",
            "properties": {
              "recommendation": {
                "type": "string",
                "description": "COMPLETE recommendation"
              },
              "priority": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "effort": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "impact": { "type": "string" }
            }
          }
        },
        "documentationMap": {
          "type": "array",
          "description": "ALL available documentation",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "path": { "type": "string" },
              "description": {
                "type": "string",
                "description": "COMPLETE documentation description"
              },
              "status": {
                "type": "string",
                "enum": ["current", "outdated", "partial"]
              }
            }
          }
        },
        "additionalNotes": {
          "type": "array",
          "description": "ALL additional notes - capture completely",
          "items": { "type": "string" }
        }
      }
    }
  }
}
