{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmad.dev/schemas/bmm/fit-criteria.schema.json",
  "title": "Fit Criteria Schema",
  "description": "Schema for fit criteria that define testable acceptance conditions organized by category (functional, non-functional, security/compliance)",
  "type": "object",
  "properties": {
    "functional": {
      "type": "array",
      "description": "Functional fit criteria - specific behaviors the system must exhibit",
      "items": {
        "type": "object",
        "required": ["criterion"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Criterion identifier (e.g., 'FC-01')"
          },
          "criterion": {
            "type": "string",
            "description": "The testable criterion statement"
          },
          "verified": {
            "type": "boolean",
            "description": "Whether this criterion has been verified/checked",
            "default": false
          },
          "verificationMethod": {
            "type": "string",
            "enum": ["test", "inspection", "demonstration", "analysis"],
            "description": "How this criterion will be verified"
          },
          "relatedRequirement": {
            "type": "string",
            "description": "Related requirement ID (FR, NFR, AR)"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "nonFunctional": {
      "type": "array",
      "description": "Non-functional fit criteria - performance, scalability, reliability targets",
      "items": {
        "type": "object",
        "required": ["criterion"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Criterion identifier (e.g., 'NFC-01')"
          },
          "category": {
            "type": "string",
            "enum": ["performance", "scalability", "reliability", "availability", "maintainability", "usability", "compatibility"],
            "description": "NFR category"
          },
          "criterion": {
            "type": "string",
            "description": "The testable criterion statement with specific metrics"
          },
          "metric": {
            "type": "object",
            "description": "Quantifiable metric for this criterion",
            "properties": {
              "measure": { "type": "string" },
              "target": { "type": "string" },
              "threshold": { "type": "string" },
              "unit": { "type": "string" }
            }
          },
          "verified": {
            "type": "boolean",
            "default": false
          },
          "verificationMethod": {
            "type": "string",
            "enum": ["benchmark", "load-test", "stress-test", "monitoring", "inspection"]
          },
          "relatedRequirement": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "security": {
      "type": "array",
      "description": "Security and compliance fit criteria",
      "items": {
        "type": "object",
        "required": ["criterion"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Criterion identifier (e.g., 'SC-01')"
          },
          "category": {
            "type": "string",
            "enum": ["authentication", "authorization", "encryption", "audit", "compliance", "data-protection", "network-security"],
            "description": "Security category"
          },
          "criterion": {
            "type": "string",
            "description": "The security/compliance criterion statement"
          },
          "complianceStandard": {
            "type": "string",
            "description": "Related compliance standard (e.g., 'HIPAA', 'GDPR', 'SOC2')"
          },
          "verified": {
            "type": "boolean",
            "default": false
          },
          "verificationMethod": {
            "type": "string",
            "enum": ["security-audit", "penetration-test", "code-review", "compliance-review", "inspection"]
          },
          "relatedRequirement": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Summary counts and verification status",
      "properties": {
        "totalFunctional": { "type": "integer" },
        "totalNonFunctional": { "type": "integer" },
        "totalSecurity": { "type": "integer" },
        "totalCriteria": { "type": "integer" },
        "verifiedCount": { "type": "integer" },
        "verificationPercentage": { "type": "string" }
      }
    }
  }
}
