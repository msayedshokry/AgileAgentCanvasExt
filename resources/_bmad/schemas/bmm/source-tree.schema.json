{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmad.dev/schemas/bmm/source-tree.schema.json",
  "title": "Source Tree Analysis Schema",
  "description": "Comprehensive schema for source tree artifacts - captures COMPLETE directory structure documentation and analysis",
  "type": "object",
  "required": ["metadata", "content"],
  "properties": {
    "metadata": {
      "$ref": "../common/metadata.schema.json"
    },
    "content": {
      "type": "object",
      "required": ["overview"],
      "properties": {
        "overview": {
          "type": "object",
          "description": "Source tree overview",
          "properties": {
            "projectName": { "type": "string" },
            "analysisDate": {
              "type": "string",
              "format": "date"
            },
            "rootPath": { "type": "string" },
            "totalFiles": { "type": "integer" },
            "totalDirectories": { "type": "integer" },
            "totalSize": { "type": "string" },
            "primaryLanguage": { "type": "string" },
            "summary": {
              "type": "string",
              "description": "COMPLETE source tree summary"
            }
          }
        },
        "statistics": {
          "type": "object",
          "description": "Source tree statistics",
          "properties": {
            "byLanguage": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "language": { "type": "string" },
                  "files": { "type": "integer" },
                  "lines": { "type": "integer" },
                  "percentage": { "type": "number" }
                }
              }
            },
            "byFileType": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "extension": { "type": "string" },
                  "count": { "type": "integer" },
                  "percentage": { "type": "number" }
                }
              }
            },
            "largestFiles": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "size": { "type": "string" },
                  "lines": { "type": "integer" }
                }
              }
            },
            "deepestPaths": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "depth": { "type": "integer" }
                }
              }
            }
          }
        },
        "multiPartStructure": {
          "type": "array",
          "description": "Multi-part structure overview (for monorepos)",
          "items": {
            "type": "object",
            "properties": {
              "partId": { "type": "string" },
              "name": { "type": "string" },
              "path": { "type": "string" },
              "description": {
                "type": "string",
                "description": "COMPLETE part description"
              },
              "files": { "type": "integer" },
              "directories": { "type": "integer" }
            }
          }
        },
        "directoryStructure": {
          "type": "array",
          "description": "COMPLETE directory structure - capture ALL directories",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["directory", "file"]
              },
              "name": { "type": "string" },
              "purpose": {
                "type": "string",
                "description": "COMPLETE purpose description"
              },
              "depth": { "type": "integer" },
              "fileCount": { "type": "integer" },
              "children": {
                "type": "array",
                "description": "Child paths",
                "items": { "type": "string" }
              },
              "keyFiles": {
                "type": "array",
                "description": "Key files in this directory",
                "items": { "type": "string" }
              },
              "conventions": {
                "type": "string",
                "description": "Naming/organization conventions"
              }
            }
          }
        },
        "criticalDirectories": {
          "type": "array",
          "description": "ALL critical directories with detailed info",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "purpose": {
                "type": "string",
                "description": "COMPLETE purpose description"
              },
              "contents": {
                "type": "string",
                "description": "COMPLETE contents description"
              },
              "fileTypes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "entryPoints": {
                "type": "array",
                "description": "Entry point files",
                "items": {
                  "type": "object",
                  "properties": {
                    "file": { "type": "string" },
                    "purpose": { "type": "string" }
                  }
                }
              },
              "keyFiles": {
                "type": "array",
                "description": "Key files in this directory",
                "items": {
                  "type": "object",
                  "properties": {
                    "file": { "type": "string" },
                    "purpose": { "type": "string" }
                  }
                }
              },
              "integrationNotes": {
                "type": "string",
                "description": "COMPLETE integration notes"
              },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "dependents": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "entryPoints": {
          "type": "array",
          "description": "ALL application entry points - capture completely",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "type": {
                "type": "string",
                "description": "Entry point type (e.g., 'main', 'test', 'script')"
              },
              "description": {
                "type": "string",
                "description": "COMPLETE entry point description"
              },
              "exports": {
                "type": "array",
                "description": "What this entry point exports",
                "items": { "type": "string" }
              },
              "usage": { "type": "string" }
            }
          }
        },
        "fileOrganizationPatterns": {
          "type": "array",
          "description": "ALL file organization patterns - capture completely",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Pattern name"
              },
              "description": {
                "type": "string",
                "description": "COMPLETE pattern description"
              },
              "locations": {
                "type": "array",
                "description": "Where this pattern is used",
                "items": { "type": "string" }
              },
              "examples": {
                "type": "array",
                "description": "Example files/directories",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "explanation": { "type": "string" }
                  }
                }
              },
              "rationale": { "type": "string" }
            }
          }
        },
        "namingConventions": {
          "type": "array",
          "description": "ALL naming conventions observed",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "What this convention applies to"
              },
              "convention": {
                "type": "string",
                "description": "COMPLETE convention description"
              },
              "pattern": { "type": "string" },
              "examples": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "keyFileTypes": {
          "type": "array",
          "description": "ALL key file types and their purposes",
          "items": {
            "type": "object",
            "properties": {
              "extension": { "type": "string" },
              "purpose": {
                "type": "string",
                "description": "COMPLETE purpose description"
              },
              "count": { "type": "integer" },
              "locations": {
                "type": "array",
                "items": { "type": "string" }
              },
              "conventions": { "type": "string" }
            }
          }
        },
        "assetLocations": {
          "type": "array",
          "description": "ALL asset locations - capture completely",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Asset type (e.g., 'images', 'fonts', 'styles')"
              },
              "path": { "type": "string" },
              "description": {
                "type": "string",
                "description": "COMPLETE description"
              },
              "formats": {
                "type": "array",
                "items": { "type": "string" }
              },
              "count": { "type": "integer" },
              "usage": { "type": "string" }
            }
          }
        },
        "configurationFiles": {
          "type": "array",
          "description": "ALL configuration files - capture completely",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "purpose": {
                "type": "string",
                "description": "COMPLETE purpose description"
              },
              "format": {
                "type": "string",
                "description": "File format (e.g., 'json', 'yaml', 'toml')"
              },
              "keySettings": {
                "type": "array",
                "description": "Key settings in this file",
                "items": {
                  "type": "object",
                  "properties": {
                    "setting": { "type": "string" },
                    "description": { "type": "string" }
                  }
                }
              },
              "environment": {
                "type": "string",
                "description": "Which environment this applies to"
              }
            }
          }
        },
        "buildArtifacts": {
          "type": "object",
          "description": "Build artifact locations",
          "properties": {
            "outputDirectory": { "type": "string" },
            "intermediateDirectories": {
              "type": "array",
              "items": { "type": "string" }
            },
            "cacheDirectories": {
              "type": "array",
              "items": { "type": "string" }
            },
            "gitIgnored": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "testLocations": {
          "type": "array",
          "description": "Test file locations",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "type": {
                "type": "string",
                "description": "Test type (unit, integration, e2e)"
              },
              "pattern": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        },
        "documentationLocations": {
          "type": "array",
          "description": "Documentation file locations",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "type": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "moduleGraph": {
          "type": "object",
          "description": "Module dependency graph",
          "properties": {
            "rootModules": {
              "type": "array",
              "items": { "type": "string" }
            },
            "dependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from": { "type": "string" },
                  "to": { "type": "string" },
                  "type": { "type": "string" }
                }
              }
            },
            "circularDependencies": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "developmentNotes": {
          "type": "array",
          "description": "ALL notes for developers - capture completely",
          "items": {
            "type": "object",
            "properties": {
              "note": {
                "type": "string",
                "description": "COMPLETE note"
              },
              "category": { "type": "string" },
              "importance": {
                "type": "string",
                "enum": ["critical", "important", "informational"]
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "description": "Structure improvement recommendations",
          "items": {
            "type": "object",
            "properties": {
              "recommendation": {
                "type": "string",
                "description": "COMPLETE recommendation"
              },
              "rationale": { "type": "string" },
              "impact": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
