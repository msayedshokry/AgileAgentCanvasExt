{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmad.dev/schemas/tea/automation-summary.schema.json",
  "title": "Test Automation Summary Schema",
  "description": "Schema for test automation expansion summary - captures coverage analysis, generated tests, and automation strategy",
  "type": "object",
  "required": [
    "metadata",
    "content"
  ],
  "properties": {
    "metadata": {
      "$ref": "../common/metadata.schema.json"
    },
    "content": {
      "type": "object",
      "required": [
        "summary",
        "coverageAnalysis"
      ],
      "properties": {
        "summary": {
          "type": "object",
          "description": "Automation summary overview",
          "properties": {
            "scope": {
              "type": "string",
              "description": "Scope of automation effort"
            },
            "mode": {
              "type": "string",
              "description": "Whether working with BMad artifacts or standalone. Recommended values: standalone, bmad-integrated — or any domain-appropriate value"
            },
            "coverageTarget": {
              "type": "string",
              "description": "Coverage target mode. Recommended values: critical-paths, comprehensive, selective — or any domain-appropriate value"
            },
            "framework": {
              "type": "string",
              "description": "Test framework used"
            },
            "totalTestsCreated": {
              "type": "integer"
            },
            "totalFilesCreated": {
              "type": "integer"
            },
            "estimatedCoverageIncrease": {
              "type": "string"
            }
          }
        },
        "coverageAnalysis": {
          "type": "object",
          "description": "Detailed coverage analysis",
          "properties": {
            "baseline": {
              "type": "object",
              "description": "Coverage before automation",
              "properties": {
                "statement": {
                  "type": "string"
                },
                "branch": {
                  "type": "string"
                },
                "function": {
                  "type": "string"
                },
                "line": {
                  "type": "string"
                },
                "e2e": {
                  "type": "string"
                }
              }
            },
            "target": {
              "type": "object",
              "description": "Target coverage after automation",
              "properties": {
                "statement": {
                  "type": "string"
                },
                "branch": {
                  "type": "string"
                },
                "function": {
                  "type": "string"
                },
                "line": {
                  "type": "string"
                },
                "e2e": {
                  "type": "string"
                }
              }
            },
            "gaps": {
              "type": "array",
              "description": "Coverage gaps identified",
              "items": {
                "type": "object",
                "properties": {
                  "area": {
                    "type": "string"
                  },
                  "currentCoverage": {
                    "type": "string"
                  },
                  "gapType": {
                    "type": "string",
                    "description": "Recommended values: uncovered, under-tested, missing-edge-cases, no-error-handling — or any domain-appropriate value"
                  },
                  "priority": {
                    "type": "string",
                    "enum": [
                      "critical",
                      "high",
                      "medium",
                      "low"
                    ]
                  },
                  "addressed": {
                    "type": "boolean"
                  }
                }
              }
            },
            "criticalPaths": {
              "type": "array",
              "description": "Critical paths identified and tested",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "testsCovering": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "covered",
                      "partially-covered",
                      "not-covered"
                    ]
                  }
                }
              }
            }
          }
        },
        "testsCreated": {
          "type": "array",
          "description": "Tests created during automation",
          "items": {
            "type": "object",
            "properties": {
              "filePath": {
                "type": "string"
              },
              "testType": {
                "type": "string",
                "description": "Recommended values: unit, integration, component, api, e2e — or any domain-appropriate value"
              },
              "targetFeature": {
                "type": "string"
              },
              "targetFiles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "testCount": {
                "type": "integer"
              },
              "tests": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "category": {
                      "type": "string",
                      "description": "Recommended values: happy-path, edge-case, error-handling, boundary, security, performance — or any domain-appropriate value"
                    },
                    "priority": {
                      "type": "string",
                      "enum": [
                        "P0",
                        "P1",
                        "P2",
                        "P3"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "fixturesCreated": {
          "type": "array",
          "description": "Test fixtures created",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "filePath": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              },
              "dataType": {
                "type": "string"
              }
            }
          }
        },
        "factoriesCreated": {
          "type": "array",
          "description": "Test data factories created",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "filePath": {
                "type": "string"
              },
              "entityType": {
                "type": "string"
              },
              "variants": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "bmadIntegration": {
          "type": "object",
          "description": "Integration with BMad artifacts (when applicable)",
          "properties": {
            "storiesReferenced": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "acceptanceCriteriaMapped": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "storyId": {
                    "type": "string"
                  },
                  "criteriaId": {
                    "type": "string"
                  },
                  "testFiles": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "traceabilityUpdated": {
              "type": "boolean"
            }
          }
        },
        "automationStrategy": {
          "type": "object",
          "description": "Strategy used for test automation",
          "properties": {
            "approach": {
              "type": "string"
            },
            "prioritization": {
              "type": "string"
            },
            "testLevels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "level": {
                    "type": "string"
                  },
                  "percentage": {
                    "type": "string"
                  },
                  "rationale": {
                    "type": "string"
                  }
                }
              }
            },
            "patternsApplied": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "pattern": {
                    "type": "string"
                  },
                  "usage": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "description": "Recommendations for future automation",
          "items": {
            "type": "object",
            "properties": {
              "area": {
                "type": "string"
              },
              "recommendation": {
                "type": "string"
              },
              "priority": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "effort": {
                "type": "string"
              },
              "impact": {
                "type": "string"
              }
            }
          }
        },
        "executionResults": {
          "type": "object",
          "description": "Results from running generated tests",
          "properties": {
            "totalTests": {
              "type": "integer"
            },
            "passed": {
              "type": "integer"
            },
            "failed": {
              "type": "integer"
            },
            "skipped": {
              "type": "integer"
            },
            "duration": {
              "type": "string"
            },
            "failureDetails": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "test": {
                    "type": "string"
                  },
                  "error": {
                    "type": "string"
                  },
                  "resolution": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
