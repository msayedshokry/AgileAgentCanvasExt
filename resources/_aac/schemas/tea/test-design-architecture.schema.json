{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bmad.dev/schemas/tea/test-design-architecture.schema.json",
  "title": "Test Design Architecture Schema",
  "description": "Schema for architecture-focused test design artifacts - testability assessment. IMPORTANT: Capture ALL architectural concerns, testability assessments, and risk details completely. Do NOT summarize or truncate any analysis.",
  "type": "object",
  "required": [
    "metadata",
    "content"
  ],
  "properties": {
    "metadata": {
      "$ref": "../common/metadata.schema.json"
    },
    "content": {
      "type": "object",
      "required": [
        "featureInfo",
        "testabilityAssessment"
      ],
      "properties": {
        "featureInfo": {
          "type": "object",
          "description": "COMPLETE feature information for architecture review",
          "required": [
            "featureName",
            "purpose"
          ],
          "properties": {
            "featureName": {
              "type": "string",
              "description": "COMPLETE name of the feature under architectural review"
            },
            "purpose": {
              "type": "string",
              "description": "COMPLETE description of the feature's purpose and architectural significance"
            },
            "prdReference": {
              "type": "string",
              "description": "Reference to the PRD document"
            },
            "adrReference": {
              "type": "string",
              "description": "Reference to relevant Architecture Decision Records"
            },
            "techSpecReference": {
              "type": "string",
              "description": "Reference to technical specification"
            },
            "affectedComponents": {
              "type": "array",
              "description": "ALL components affected by this feature",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "executiveSummary": {
          "type": "object",
          "description": "COMPLETE executive summary of the architectural testability assessment",
          "properties": {
            "businessContext": {
              "type": "string",
              "description": "COMPLETE business context and drivers for this feature. Include all relevant business requirements and constraints."
            },
            "architecture": {
              "type": "string",
              "description": "COMPLETE architectural overview including all major components, interactions, and design patterns used."
            },
            "expectedScale": {
              "type": "string",
              "description": "COMPLETE description of expected scale including user volumes, data volumes, transaction rates, and growth projections."
            },
            "riskSummary": {
              "type": "string",
              "description": "COMPLETE summary of key architectural risks and their potential impact on testability."
            },
            "testabilityVerdict": {
              "type": "string",
              "description": "COMPLETE verdict on overall testability with supporting rationale"
            }
          }
        },
        "architectureOverview": {
          "type": "object",
          "description": "COMPLETE architecture overview for testability analysis",
          "properties": {
            "diagram": {
              "type": "string",
              "description": "Architecture diagram (mermaid, PlantUML, or ASCII)"
            },
            "components": {
              "type": "array",
              "description": "ALL architectural components with full details",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "description": "Recommended values: service, database, queue, cache, api, ui, external, other — or any domain-appropriate value"
                  },
                  "description": {
                    "type": "string",
                    "description": "COMPLETE component description"
                  },
                  "technology": {
                    "type": "string"
                  },
                  "testabilityNotes": {
                    "type": "string",
                    "description": "COMPLETE testability considerations for this component"
                  },
                  "dependencies": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "dataFlows": {
              "type": "array",
              "description": "ALL data flows with full details",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string"
                  },
                  "destination": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string",
                    "description": "COMPLETE data flow description"
                  },
                  "testabilityConsiderations": {
                    "type": "string"
                  }
                }
              }
            },
            "integrationPoints": {
              "type": "array",
              "description": "ALL integration points with full details",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "description": "Recommended values: api, event, database, file, message-queue, other — or any domain-appropriate value"
                  },
                  "systems": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "description": {
                    "type": "string"
                  },
                  "testStrategy": {
                    "type": "string",
                    "description": "COMPLETE strategy for testing this integration point"
                  }
                }
              }
            }
          }
        },
        "quickGuide": {
          "type": "object",
          "description": "Quick reference guide for development team",
          "properties": {
            "blockers": {
              "type": "array",
              "description": "ALL blocking issues that must be resolved before proceeding",
              "items": {
                "type": "object",
                "properties": {
                  "issue": {
                    "type": "string",
                    "description": "COMPLETE description of the blocking issue"
                  },
                  "impact": {
                    "type": "string",
                    "description": "COMPLETE description of the impact"
                  },
                  "resolution": {
                    "type": "string",
                    "description": "COMPLETE resolution path"
                  },
                  "owner": {
                    "type": "string"
                  }
                }
              }
            },
            "highPriority": {
              "type": "array",
              "description": "ALL high priority items requiring attention",
              "items": {
                "type": "object",
                "properties": {
                  "item": {
                    "type": "string",
                    "description": "COMPLETE description of the high priority item"
                  },
                  "rationale": {
                    "type": "string",
                    "description": "COMPLETE rationale for high priority"
                  },
                  "recommendation": {
                    "type": "string"
                  }
                }
              }
            },
            "infoOnly": {
              "type": "array",
              "description": "Informational items for awareness",
              "items": {
                "type": "object",
                "properties": {
                  "item": {
                    "type": "string"
                  },
                  "context": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "riskAssessment": {
          "type": "array",
          "description": "COMPLETE architectural risk assessment. Include ALL identified risks with full analysis.",
          "items": {
            "type": "object",
            "required": [
              "riskId",
              "risk",
              "probability",
              "impact",
              "mitigation"
            ],
            "properties": {
              "riskId": {
                "type": "string",
                "description": "Unique risk identifier (e.g. 'RISK-1', 'R-1')"
              },
              "category": {
                "type": "string",
                "description": "Architectural risk category. Recommended values: scalability, reliability, security, performance, integration, testability, maintainability, operability — or any domain-appropriate value"
              },
              "risk": {
                "type": "string",
                "description": "COMPLETE description of the architectural risk. Include all context, root causes, and potential consequences."
              },
              "probability": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ],
                "description": "Probability of risk materializing"
              },
              "impact": {
                "type": "string",
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ],
                "description": "Impact on system if risk materializes"
              },
              "architecturalConcern": {
                "type": "string",
                "description": "COMPLETE description of the underlying architectural concern. Explain which architectural decisions or patterns contribute to this risk."
              },
              "affectedComponents": {
                "type": "array",
                "description": "ALL components affected by this risk",
                "items": {
                  "type": "string"
                }
              },
              "mitigation": {
                "type": "string",
                "description": "COMPLETE mitigation strategy including specific architectural changes, design patterns, or testing approaches."
              },
              "testingImplications": {
                "type": "string",
                "description": "COMPLETE description of how this risk affects testing strategy"
              },
              "owner": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "identified",
                  "analyzing",
                  "mitigating",
                  "accepted",
                  "resolved"
                ]
              }
            }
          }
        },
        "testabilityConcerns": {
          "type": "array",
          "description": "COMPLETE list of ALL testability concerns and architectural gaps",
          "items": {
            "type": "object",
            "required": [
              "concern",
              "component",
              "impact",
              "recommendation"
            ],
            "properties": {
              "concernId": {
                "type": "string",
                "description": "Unique concern identifier"
              },
              "concern": {
                "type": "string",
                "description": "COMPLETE description of the testability concern. Include specific technical details."
              },
              "component": {
                "type": "string",
                "description": "Component or area where the concern exists"
              },
              "impact": {
                "type": "string",
                "description": "COMPLETE description of the impact on testing. Explain what cannot be tested or what testing challenges this creates."
              },
              "severity": {
                "type": "string",
                "enum": [
                  "blocker",
                  "critical",
                  "major",
                  "minor"
                ],
                "description": "Severity of the testability concern"
              },
              "recommendation": {
                "type": "string",
                "description": "COMPLETE recommendation for addressing this concern. Include specific technical solutions."
              },
              "effort": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ],
                "description": "Estimated effort to address"
              },
              "status": {
                "type": "string",
                "enum": [
                  "open",
                  "in-progress",
                  "resolved",
                  "accepted"
                ],
                "description": "Current status of this concern"
              }
            }
          }
        },
        "testabilityAssessment": {
          "type": "object",
          "description": "COMPLETE testability assessment across all categories",
          "required": [
            "overall",
            "categories"
          ],
          "properties": {
            "overall": {
              "type": "string",
              "enum": [
                "good",
                "moderate",
                "poor"
              ],
              "description": "Overall testability rating"
            },
            "overallNotes": {
              "type": "string",
              "description": "COMPLETE explanation of the overall rating with supporting evidence"
            },
            "categories": {
              "type": "array",
              "description": "COMPLETE assessment for each testability category",
              "items": {
                "type": "object",
                "required": [
                  "category",
                  "rating",
                  "notes"
                ],
                "properties": {
                  "category": {
                    "type": "string",
                    "description": "Testability category (e.g., observability, controllability, isolation, etc.)"
                  },
                  "rating": {
                    "type": "string",
                    "enum": [
                      "good",
                      "moderate",
                      "poor"
                    ],
                    "description": "Rating for this category"
                  },
                  "notes": {
                    "type": "string",
                    "description": "COMPLETE notes explaining the rating with specific examples and evidence"
                  },
                  "recommendations": {
                    "type": "array",
                    "description": "Recommendations for improvement",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "observability": {
              "type": "object",
              "description": "Detailed observability assessment",
              "properties": {
                "logging": {
                  "type": "string",
                  "description": "COMPLETE assessment of logging capabilities for testing"
                },
                "metrics": {
                  "type": "string",
                  "description": "COMPLETE assessment of metrics availability for testing"
                },
                "tracing": {
                  "type": "string",
                  "description": "COMPLETE assessment of distributed tracing capabilities"
                },
                "healthChecks": {
                  "type": "string",
                  "description": "COMPLETE assessment of health check endpoints"
                }
              }
            },
            "controllability": {
              "type": "object",
              "description": "Detailed controllability assessment",
              "properties": {
                "stateManagement": {
                  "type": "string",
                  "description": "COMPLETE assessment of ability to control system state"
                },
                "featureFlags": {
                  "type": "string",
                  "description": "COMPLETE assessment of feature flag capabilities"
                },
                "testHooks": {
                  "type": "string",
                  "description": "COMPLETE assessment of test hooks and seams"
                }
              }
            },
            "isolation": {
              "type": "object",
              "description": "Detailed isolation assessment",
              "properties": {
                "componentIsolation": {
                  "type": "string",
                  "description": "COMPLETE assessment of component isolation capabilities"
                },
                "dataIsolation": {
                  "type": "string",
                  "description": "COMPLETE assessment of data isolation for testing"
                },
                "environmentIsolation": {
                  "type": "string",
                  "description": "COMPLETE assessment of environment isolation"
                }
              }
            }
          }
        },
        "riskMitigationPlans": {
          "type": "array",
          "description": "COMPLETE risk mitigation plans with full details",
          "items": {
            "type": "object",
            "required": [
              "risk",
              "plan"
            ],
            "properties": {
              "planId": {
                "type": "string",
                "description": "Unique plan identifier"
              },
              "risk": {
                "type": "string",
                "description": "Reference to the risk being mitigated"
              },
              "plan": {
                "type": "string",
                "description": "COMPLETE mitigation plan with all steps and considerations"
              },
              "architecturalChanges": {
                "type": "array",
                "description": "Required architectural changes",
                "items": {
                  "type": "object",
                  "properties": {
                    "change": {
                      "type": "string"
                    },
                    "component": {
                      "type": "string"
                    },
                    "effort": {
                      "type": "string"
                    }
                  }
                }
              },
              "testingRequirements": {
                "type": "array",
                "description": "Testing requirements for validation",
                "items": {
                  "type": "string"
                }
              },
              "owner": {
                "type": "string",
                "description": "Owner responsible for execution"
              },
              "timeline": {
                "type": "string",
                "description": "Expected timeline for completion"
              },
              "status": {
                "type": "string",
                "enum": [
                  "planned",
                  "in-progress",
                  "completed",
                  "blocked"
                ],
                "description": "Current status"
              },
              "successCriteria": {
                "type": "array",
                "description": "Criteria for successful mitigation",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "architecturalRecommendations": {
          "type": "array",
          "description": "COMPLETE architectural recommendations for improving testability",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "recommendation": {
                "type": "string",
                "description": "COMPLETE recommendation with technical details"
              },
              "rationale": {
                "type": "string",
                "description": "COMPLETE rationale explaining why this improves testability"
              },
              "affectedComponents": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "effort": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "priority": {
                "type": "string",
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ]
              },
              "implementationGuidance": {
                "type": "string",
                "description": "COMPLETE implementation guidance"
              }
            }
          }
        },
        "assumptionsAndDependencies": {
          "type": "object",
          "description": "COMPLETE list of assumptions and dependencies",
          "properties": {
            "assumptions": {
              "type": "array",
              "description": "ALL assumptions made in this assessment",
              "items": {
                "type": "object",
                "properties": {
                  "assumption": {
                    "type": "string",
                    "description": "COMPLETE description of the assumption"
                  },
                  "impact": {
                    "type": "string",
                    "description": "Impact if assumption is invalid"
                  },
                  "validationApproach": {
                    "type": "string",
                    "description": "How to validate this assumption"
                  }
                }
              }
            },
            "dependencies": {
              "type": "array",
              "description": "ALL dependencies for this assessment and its recommendations",
              "items": {
                "type": "object",
                "properties": {
                  "dependency": {
                    "type": "string",
                    "description": "COMPLETE description of the dependency"
                  },
                  "type": {
                    "type": "string",
                    "description": "Recommended values: technical, team, timeline, resource, external — or any domain-appropriate value"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "confirmed",
                      "pending",
                      "at-risk"
                    ]
                  },
                  "mitigation": {
                    "type": "string",
                    "description": "Mitigation if dependency is not met"
                  }
                }
              }
            }
          }
        },
        "nextSteps": {
          "type": "array",
          "description": "COMPLETE list of recommended next steps",
          "items": {
            "type": "object",
            "properties": {
              "step": {
                "type": "string",
                "description": "COMPLETE description of the next step"
              },
              "owner": {
                "type": "string"
              },
              "timeline": {
                "type": "string"
              },
              "priority": {
                "type": "string",
                "enum": [
                  "immediate",
                  "short-term",
                  "medium-term",
                  "long-term"
                ]
              }
            }
          }
        },
        "signOff": {
          "type": "object",
          "description": "Architecture review sign-off",
          "properties": {
            "reviewedBy": {
              "type": "string"
            },
            "reviewDate": {
              "type": "string",
              "format": "date"
            },
            "verdict": {
              "type": "string",
              "enum": [
                "approved",
                "approved-with-conditions",
                "needs-revision",
                "rejected"
              ]
            },
            "conditions": {
              "type": "array",
              "description": "Conditions for approval",
              "items": {
                "type": "string"
              }
            },
            "comments": {
              "type": "string",
              "description": "COMPLETE reviewer comments"
            }
          }
        }
      }
    }
  }
}
