{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agileagentcanvas.dev/schemas/arch-index.schema.json",
  "title": "ArchIndex",
  "description": "Schema for graphify-out/ARCH_INDEX.json — the condensed Architecture Index generated by `graphify index .`",
  "type": "object",
  "required": ["repo", "generatedAt", "stats", "communities", "globalGodNodes", "crossCommunityEdges", "navigation"],
  "additionalProperties": false,
  "properties": {
    "repo": {
      "type": "string",
      "description": "Repository root directory name or path."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the index was generated."
    },
    "stats": {
      "type": "object",
      "description": "Summary statistics about the codebase graph.",
      "required": ["files", "nodes", "edges", "communities"],
      "additionalProperties": false,
      "properties": {
        "files": { "type": "integer", "minimum": 0 },
        "nodes": { "type": "integer", "minimum": 0 },
        "edges": { "type": "integer", "minimum": 0 },
        "communities": { "type": "integer", "minimum": 0 }
      }
    },
    "communities": {
      "type": "array",
      "description": "Detected code communities (modules/domains) from graph clustering.",
      "items": {
        "type": "object",
        "required": ["id", "label", "directories", "fileCount", "nodeCount", "godNodes", "neighbors", "summary"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "integer", "description": "Community integer ID from clustering." },
          "label": { "type": "string", "description": "Human-readable community label." },
          "directories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Representative directories for this community."
          },
          "fileCount": { "type": "integer", "minimum": 0 },
          "nodeCount": { "type": "integer", "minimum": 0 },
          "godNodes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "High-degree (hub) node labels within this community."
          },
          "neighbors": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "IDs of neighboring communities with cross-community edges."
          },
          "summary": {
            "type": "string",
            "description": "Short human-readable description of this community's purpose."
          }
        }
      }
    },
    "globalGodNodes": {
      "type": "array",
      "description": "Top hub nodes across the entire graph (by degree).",
      "items": {
        "type": "object",
        "required": ["id", "label", "degree", "community"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Node ID from graph.json." },
          "label": { "type": "string" },
          "degree": { "type": "integer", "minimum": 0 },
          "community": {
            "oneOf": [{ "type": "integer" }, { "type": "null" }],
            "description": "Community ID this node belongs to, or null if unclustered."
          }
        }
      }
    },
    "crossCommunityEdges": {
      "type": "array",
      "description": "Significant edges between different communities.",
      "items": {
        "type": "object",
        "required": ["from", "to", "edgeCount", "topRelations"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "integer", "description": "Source community ID." },
          "to": { "type": "integer", "description": "Target community ID." },
          "edgeCount": { "type": "integer", "minimum": 1 },
          "topRelations": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Labels of the most significant cross-community edges."
          }
        }
      }
    },
    "navigation": {
      "type": "object",
      "description": "Relative paths to companion graphify output files.",
      "required": ["fullReport", "wiki", "graph"],
      "additionalProperties": false,
      "properties": {
        "fullReport": { "type": "string", "description": "Relative path to GRAPH_REPORT.md." },
        "wiki": { "type": "string", "description": "Relative path to the wiki directory." },
        "graph": { "type": "string", "description": "Relative path to graph.json." }
      }
    }
  }
}
