# Silences npm install-time lifecycle hooks so transitive deps (notably
# `node-pty@1.1.0#scripts.install: "node scripts/prebuild.js || node-gyp rebuild"`
# and `#scripts.postinstall: "node scripts/postinstall.js"`) cannot silently
# re-link `node_modules/node-pty/prebuilds/linux-x64/pty.node` against the
# host's Node ABI rather than the Electron ABI the prepublish guard pins.
#
# Direct CLI rebuild invocations still fire -- `scripts/prepublish-guard.js`
# invokes `npm run rebuild:node-pty` (which runs `npx @electron/rebuild` as
# a child process on Linux hosts) before each `vsce package`, so the
# Electron-ABI build keeps working.
#
# One-shot escape hatch for contributors who need a specific lifecycle
# hook to fire (e.g. a transitive dep that requires `postinstall`):
#   npm install --ignore-scripts=false
# New contributors: run `npm run bootstrap:hooks` once after `git clone` to set
# up the pre-commit githooks (suppressed by ignore-scripts above).
ignore-scripts=true
