e={{ fontSize: '0.85em' }}><code>{t.filePath}</code></div>}\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            ))}\r\n          </CollapsibleSection>\r\n        ) : null;\r\n      })", "is_member_call": false, "source_file": "D:\\PersonalDev\\AgileAgentCanvas\\AgileAgentCanvasExt\\webview-ui\\src\\components\\renderers\\tea-renderers.tsx", "source_location": "L859"}, {"caller_nid": "renderers_tea_renderers_renderatddchecklistdetails", "callee": "map", "is_member_call": true, "source_file": "D:\\PersonalDev\\AgileAgentCanvas\\AgileAgentCanvasExt\\webview-ui\\src\\components\\renderers\\tea-renderers.tsx", "source_location": "L887"}, {"caller_nid": "renderers_tea_renderers_renderatddchecklistdetails", "callee": "map", "is_member_call": true, "source_file": "D:\\PersonalDev\\AgileAgentCanvas\\AgileAgentCanvasExt\\webview-ui\\src\\components\\renderers\\tea-renderers.tsx", "source_location": "L904"}, {"caller_nid": "renderers_tea_renderers_renderatddchecklistdetails", "callee": "map", "is_member_call": true, "source_file": "D:\\PersonalDev\\AgileAgentCanvas\\AgileAgentCanvasExt\\webview-ui\\src\\components\\renderers\\tea-renderers.tsx", "source_location": "L924"}, {"caller_nid": "renderers_tea_renderers_renderatddchecklistdetails", "callee": "some", "is_member_call": true, "source_file": "D:\\PersonalDev\\AgileAgentCanvas\\AgileAgentCanvasExt\\webview-ui\\src\\components\\renderers\\tea-renderers.tsx", "source_location": "L951"}, {"caller_nid": "renderers_tea_renderers_renderatddchecklistdetails", "callee": "values", "is_member_call": true, "source_file": "D:\\PersonalDev\\AgileAgentCanvas\\AgileAgentCanvasExt\\webview-ui\\src\\components\\renderers\\tea-renderers.tsx", "source_location": "L951"}, {"caller_nid": "renderers_tea_renderers_renderatddchecklistdetails", "callee": "map", "is_member_call": true, "source_file": "D:\\PersonalDev\\AgileAgentCanvas\\AgileAgentCanvasExt\\webview-ui\\src\\components\\renderers\\tea-renderers.t